{
  "name": "bizbil",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "corepack pnpm -r --if-present build",
    "lint": "corepack pnpm -r --if-present lint",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "test": "corepack pnpm -r --if-present test",
    "check": "corepack pnpm --filter @bizbil/shared build && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test"
  },
  "devDependencies": {
    "@bizbil/eslint-config": "workspace:*",
    "@types/node": "^20.17.10",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
