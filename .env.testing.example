# Testing environment. Do not reuse production secrets.
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=testing
TEST_HTTP_PORT=3100

# Public test URL.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_APP_URL=https://test.bizbil.com
NEXT_PUBLIC_APP_NAME=BizBil Testing
TEST_APP_DOMAIN=test.bizbil.com

# Public storefront
STOREFRONT_DELIVERY_CHARGE=0
STOREFRONT_FREE_DELIVERY_ABOVE=0

# Database
POSTGRES_DB=retailos_test
POSTGRES_USER=retailos
POSTGRES_PASSWORD=change-me-testing-postgres
DATABASE_URL=postgresql://retailos:change-me-testing-postgres@postgres:5432/retailos_test

# Redis
REDIS_PASSWORD=change-me-testing-redis
REDIS_URL=redis://:change-me-testing-redis@redis:6379

# MinIO / Object storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=retailos-test
MINIO_ROOT_PASSWORD=change-me-testing-minio
MINIO_BUCKET=retailos-test

# Auth
JWT_SECRET=replace-with-a-long-random-testing-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# Razorpay - testing keys only
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=replace-me-testing
RAZORPAY_WEBHOOK_SECRET=replace-me-testing

# WhatsApp - keep blank unless deliberately testing WhatsApp
WHATSAPP_SESSION_PATH=/app/whatsapp-session
WHATSAPP_PRINT_QR=false
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=retailos-testing-whatsapp-verify-token
WHATSAPP_WEBHOOK_APP_SECRET=
WHATSAPP_WEBHOOK_SECRET=retailos-testing-whatsapp-shared-secret
WHATSAPP_EMBEDDED_APP_ID=
WHATSAPP_EMBEDDED_CONFIG_ID=
WHATSAPP_EMBEDDED_APP_SECRET=
WHATSAPP_TOKEN_ENCRYPTION_KEY=replace-with-32-plus-random-testing-characters

# Frontend
NEXT_PUBLIC_STOREFRONT_ROOT_DOMAIN=bizbil.com
NEXT_PUBLIC_STOREFRONT_CUSTOM_HOSTS=sivsanoils.in,www.sivsanoils.in

# Public storefront
STOREFRONT_ROOT_DOMAIN=bizbil.com
STOREFRONT_SECRET_ENCRYPTION_KEY=replace-with-32-plus-random-testing-characters
STOREFRONT_DELIVERY_CHARGE=0
STOREFRONT_FREE_DELIVERY_ABOVE=0

# Product image discovery (Google Programmable Search / Custom Search JSON API)
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
GOOGLE_CUSTOM_SEARCH_SAFE=active
GOOGLE_CUSTOM_SEARCH_COUNTRY=in
GOOGLE_CUSTOM_SEARCH_LANGUAGE=en
GOOGLE_CUSTOM_SEARCH_IMAGE_RIGHTS=

# SMS OTP
FAST2SMS_API_KEY=

# Delivery routing / geocoding. Keep blank until the test routing stack is running.
GEOCODER_BASE_URL=
VROOM_BASE_URL=
OSRM_BASE_URL=
