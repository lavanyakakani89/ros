# Public domains
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production
APP_DOMAIN=bizbil.com
TEST_APP_DOMAIN=test.bizbil.com
ACME_EMAIL=admin@example.com

# Database
POSTGRES_DB=bizbil
POSTGRES_USER=bizbil
POSTGRES_PASSWORD=change-me-postgres
DATABASE_URL=postgresql://bizbil:change-me-postgres@postgres:5432/bizbil

# Redis
REDIS_PASSWORD=change-me-redis
REDIS_URL=redis://:change-me-redis@redis:6379

# MinIO / Object storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=bizbil
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_BUCKET=bizbil

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=replace-me
RAZORPAY_WEBHOOK_SECRET=replace-me

# WhatsApp (Baileys)
WHATSAPP_SESSION_PATH=/app/whatsapp-session
WHATSAPP_PRINT_QR=false
WHATSAPP_CLOUD_ACCESS_TOKEN=replace-me-cloud-api-token
WHATSAPP_CLOUD_PHONE_NUMBER_ID=replace-me-phone-number-id
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-me-whatsapp-verify-token
WHATSAPP_WEBHOOK_APP_SECRET=replace-me-meta-app-secret
WHATSAPP_WEBHOOK_SECRET=replace-me-manual-webhook-secret
WHATSAPP_EMBEDDED_APP_ID=replace-me-meta-app-id
WHATSAPP_EMBEDDED_CONFIG_ID=replace-me-meta-embedded-signup-config-id
WHATSAPP_EMBEDDED_APP_SECRET=replace-me-meta-app-secret
WHATSAPP_TOKEN_ENCRYPTION_KEY=replace-with-32-plus-random-characters

# Frontend
NEXT_PUBLIC_API_URL=https://bizbil.com/api
NEXT_PUBLIC_APP_URL=https://bizbil.com
NEXT_PUBLIC_APP_NAME=BizBil
NEXT_PUBLIC_STOREFRONT_ROOT_DOMAIN=bizbil.com
NEXT_PUBLIC_STOREFRONT_CUSTOM_HOSTS=sivsanoils.in,www.sivsanoils.in

# Public storefront
STOREFRONT_ROOT_DOMAIN=bizbil.com
STOREFRONT_SECRET_ENCRYPTION_KEY=replace-with-32-plus-random-characters
STOREFRONT_DELIVERY_CHARGE=0
STOREFRONT_FREE_DELIVERY_ABOVE=0

# Product image discovery (Google Programmable Search / Custom Search JSON API)
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
GOOGLE_CUSTOM_SEARCH_SAFE=active
GOOGLE_CUSTOM_SEARCH_COUNTRY=in
GOOGLE_CUSTOM_SEARCH_LANGUAGE=en
GOOGLE_CUSTOM_SEARCH_IMAGE_RIGHTS=

# SMS OTP
FAST2SMS_API_KEY=replace-me

# Delivery routing / geocoding. Enable only after validating in testing.
GEOCODER_BASE_URL=
VROOM_BASE_URL=
OSRM_BASE_URL=

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana
