# Public domains
NODE_ENV=production
APP_DOMAIN=retailos.example.com
ACME_EMAIL=admin@example.com

# Database
POSTGRES_DB=retailos
POSTGRES_USER=retailos
POSTGRES_PASSWORD=change-me-postgres
DATABASE_URL=postgresql://retailos:change-me-postgres@postgres:5432/retailos

# Redis
REDIS_PASSWORD=change-me-redis
REDIS_URL=redis://:change-me-redis@redis:6379

# MinIO / Object storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=retailos
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_BUCKET=retailos

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=replace-me
RAZORPAY_WEBHOOK_SECRET=replace-me

# WhatsApp (Baileys)
WHATSAPP_SESSION_PATH=/app/whatsapp-session

# Frontend
NEXT_PUBLIC_API_URL=https://retailos.example.com/api
NEXT_PUBLIC_APP_NAME=RetailOS

# SMS OTP
FAST2SMS_API_KEY=replace-me

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana
