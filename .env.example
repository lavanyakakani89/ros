# Database
POSTGRES_DB=bizbil
POSTGRES_USER=bizbil
POSTGRES_PASSWORD=password
DATABASE_URL=postgresql://bizbil:password@localhost:15432/bizbil

# Redis
REDIS_PASSWORD=password
REDIS_URL=redis://:password@localhost:6379

# MinIO / Object storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=bizbil
MINIO_ROOT_PASSWORD=your-minio-password
MINIO_BUCKET=bizbil

# Auth
JWT_SECRET=your-very-long-random-jwt-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
PHONEPE_SECRET_ENCRYPTION_KEY=replace-with-32-plus-random-characters

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# WhatsApp (Baileys)
WHATSAPP_SESSION_PATH=./whatsapp-session
WHATSAPP_PRINT_QR=false
# WhatsApp Cloud API outbound. If these are blank, BizBil falls back to Baileys.
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v23.0
# WhatsApp inbound order webhook. Use APP_SECRET for Meta signed webhooks; use SECRET for manual/testing webhooks.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=bizbil-whatsapp-verify-token
WHATSAPP_WEBHOOK_APP_SECRET=
WHATSAPP_WEBHOOK_SECRET=bizbil-whatsapp-shared-secret
# WhatsApp Embedded Signup. These let each shop connect its own WhatsApp Business number from Settings.
WHATSAPP_EMBEDDED_APP_ID=
WHATSAPP_EMBEDDED_CONFIG_ID=
WHATSAPP_EMBEDDED_APP_SECRET=
WHATSAPP_TOKEN_ENCRYPTION_KEY=replace-with-32-plus-random-characters

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Keep this public URL correct for PhonePe callback verification and payment links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BizBil
NEXT_PUBLIC_STOREFRONT_TENANT_SLUG=sivsanoils
NEXT_PUBLIC_STOREFRONT_ROOT_DOMAIN=bizbil.com
NEXT_PUBLIC_STOREFRONT_CUSTOM_HOSTS=sivsanoils.in,www.sivsanoils.in

# Public storefront
STOREFRONT_ROOT_DOMAIN=bizbil.com
STOREFRONT_SECRET_ENCRYPTION_KEY=replace-with-32-plus-random-characters
STOREFRONT_DELIVERY_CHARGE=0
STOREFRONT_FREE_DELIVERY_ABOVE=0

# Product image discovery (Google Programmable Search / Custom Search JSON API)
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
GOOGLE_CUSTOM_SEARCH_SAFE=active
GOOGLE_CUSTOM_SEARCH_COUNTRY=in
GOOGLE_CUSTOM_SEARCH_LANGUAGE=en
# Optional Creative Commons filter, for example: cc_publicdomain|cc_attribute
GOOGLE_CUSTOM_SEARCH_IMAGE_RIGHTS=

# SMS OTP
FAST2SMS_API_KEY=your-fast2sms-key

# Delivery routing / geocoding (optional; enable in testing first)
# GEOCODER_BASE_URL=https://nominatim.openstreetmap.org/search
# VROOM_BASE_URL=http://vroom:3000
# OSRM_BASE_URL=http://osrm:5000
