  @@map("employees")
}

enum SalaryType {
  MONTHLY
  DAILY
  HOURLY
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum UnusedPaidLeavePolicy {
  NONE
  PAY_IN_PAYROLL
}

model Attendance {
  id              String           @id @default(cuid())
  employeeId      String           @map("employee_id")
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date            DateTime         @db.Date
  status          AttendanceStatus
  shiftStart      DateTime?        @map("shift_start") @db.Time
  shiftEnd        DateTime?        @map("shift_end") @db.Time
  overtimeMinutes Int              @default(0) @map("overtime_minutes")
  note            String?

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  ON_DUTY
}

model PayAdvance {
  id             String           @id @default(cuid())
  employeeId     String           @map("employee_id")
  employee       Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  amount         Decimal          @db.Decimal(10, 2)
  reason         String?
  status         PayAdvanceStatus @default(PENDING)
  requestedAt    DateTime         @default(now()) @map("requested_at")
  approvedAt     DateTime?        @map("approved_at")
  approvedBy     String?          @map("approved_by")
  recoveredIn    String?          @map("recovered_in")
  recoveredInRun PayrollRun?      @relation("RecoveredPayAdvances", fields: [recoveredIn], references: [id])

  @@index([employeeId])
  @@index([recoveredIn])
  @@map("pay_advances")
}

enum PayAdvanceStatus {
  PENDING
  APPROVED
  REJECTED
  RECOVERED
}

model PayrollRun {
  id                String        @id @default(cuid())
  tenantId          String        @map("tenant_id")
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period            String
  runAt             DateTime      @default(now()) @map("run_at")
  generatedAt       DateTime?     @map("generated_at")
  status            PayrollStatus @default(DRAFT)
  runBy             String?       @map("run_by")
  notes             String?
  payslipLines      PayslipLine[]
  recoveredAdvances PayAdvance[]  @relation("RecoveredPayAdvances")
  disbursements     PayrollDisbursement[]

  @@unique([tenantId, period])
  @@index([tenantId, status])
  @@map("payroll_runs")
}

model EmployeeSalaryRevision {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId    String    @map("employee_id")
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  previousSalary Decimal? @map("previous_salary") @db.Decimal(10, 2)
  newSalary     Decimal   @map("new_salary") @db.Decimal(10, 2)
  effectiveFrom DateTime  @map("effective_from") @db.Date
  reason        String?
  changedById   String?   @map("changed_by")
  changedBy     User?     @relation("EmployeeSalaryRevisionChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([tenantId, employeeId, effectiveFrom])
  @@map("employee_salary_revisions")
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

model PayslipLine {
  id               String     @id @default(cuid())
  payrollRunId     String     @map("payroll_run_id")
  payrollRun       PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId       String     @map("employee_id")
  employee         Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  daysWorked       Decimal    @map("days_worked") @db.Decimal(6, 2)
  overtimeHours    Decimal    @map("overtime_hours") @db.Decimal(8, 2)
  grossPay         Decimal    @map("gross_pay") @db.Decimal(10, 2)
  overtimePay      Decimal    @map("overtime_pay") @db.Decimal(10, 2)
  advancesDeducted Decimal    @map("advances_deducted") @db.Decimal(10, 2)
  otherDeductions  Decimal    @map("other_deductions") @db.Decimal(10, 2)
  netPay           Decimal    @map("net_pay") @db.Decimal(10, 2)
  breakdown        Json
  disbursement     PayrollDisbursement?

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
  @@map("payslip_lines")
}

model PayrollDisbursement {
  id                 String        @id @default(cuid())
  tenantId           String        @map("tenant_id")
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollRunId       String        @map("payroll_run_id")
  payrollRun         PayrollRun    @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  payslipLineId      String        @unique @map("payslip_line_id")
  payslipLine        PayslipLine   @relation(fields: [payslipLineId], references: [id], onDelete: Cascade)
  employeeId         String        @map("employee_id")
  employee           Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  paymentMethodId    String        @map("payment_method_id")
  paymentMethod      PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  amount             Decimal       @db.Decimal(12, 2)
  referenceNumber    String?       @map("reference_number") @db.VarChar(128)
  paidAt             DateTime      @default(now()) @map("paid_at")
  paidById           String?       @map("paid_by")
  paidBy             User?         @relation("PayrollDisbursementPaidBy", fields: [paidById], references: [id], onDelete: SetNull)
  voidedAt           DateTime?     @map("voided_at")
  voidReason         String?       @map("void_reason")
  voidAuthorisedById String?       @map("void_authorised_by")
  voidAuthorisedBy   User?         @relation("PayrollDisbursementVoidAuthoriser", fields: [voidAuthorisedById], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now()) @map("created_at")

  @@index([tenantId, payrollRunId])
  @@index([tenantId, employeeId])
  @@index([paymentMethodId, paidAt])
  @@map("payroll_disbursements")
}
