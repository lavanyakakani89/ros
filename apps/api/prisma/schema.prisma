  passwordHash   String              @map("password_hash")
  role           SuperAdminRole      @default(SUPPORT)
  isActive       Boolean             @default(true) @map("is_active")
  createdById    String?             @map("created_by_id")
  createdBy      SuperAdmin?         @relation("SuperAdminCreatedBy", fields: [createdById], references: [id])
  createdAdmins  SuperAdmin[]        @relation("SuperAdminCreatedBy")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  sessions       SuperAdminSession[]
  activityLogs   SuperAdminLog[]
  impersonationSessions ImpersonationSession[]

  @@map("super_admins")
}

enum SuperAdminRole {
  OWNER
  MANAGER
  SUPPORT
}

model SuperAdminSession {
  id           String     @id @default(cuid())
  superAdminId String     @map("super_admin_id")
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id])
  tokenHash    String     @map("token_hash")
  expiresAt    DateTime   @map("expires_at")
  revokedAt    DateTime?  @map("revoked_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([superAdminId])
  @@index([expiresAt])
  @@map("super_admin_sessions")
}

enum ImpersonationAccessLevel {
  READ_ONLY
  WRITE
}

enum ImpersonationEndReason {
  EXIT
  EXPIRED
  FORCE_ENDED
}

model ImpersonationSession {
  id            String                   @id @default(cuid())
  superAdminId  String                   @map("super_admin_id")
  superAdmin    SuperAdmin               @relation(fields: [superAdminId], references: [id])
  tenantId      String                   @map("tenant_id")
  tenant        Tenant                   @relation(fields: [tenantId], references: [id])
  accessLevel   ImpersonationAccessLevel @map("access_level")
  reason        String?
  tokenHash     String?                  @map("token_hash")
  expiresAt     DateTime                 @map("expires_at")
  endedAt       DateTime?                @map("ended_at")
  endReason     ImpersonationEndReason?  @map("end_reason")
  actionsCount  Int                      @default(0) @map("actions_count")
  ipAddress     String?                  @map("ip_address")
  userAgent     String?                  @map("user_agent")
  createdAt     DateTime                 @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([superAdminId])
  @@index([expiresAt])
  @@index([endedAt])
  @@map("impersonation_sessions")
}

model SuperAdminLog {
  id           String     @id @default(cuid())
  superAdminId String     @map("super_admin_id")
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id])
  action       String
  targetType   String?    @map("target_type")
  targetId     String?    @map("target_id")
  notes        String?
  metadata     Json?
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([superAdminId])
  @@index([targetType, targetId])
  @@map("super_admin_logs")
}

model TenantLicense {
  id               String       @id @default(cuid())
  tenantId         String       @unique @map("tenant_id")
  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  plan             LicensePlan
  billingCycle     BillingCycle @map("billing_cycle")
  startDate        DateTime     @map("start_date")
  expiryDate       DateTime     @map("expiry_date")
  amountPaid       Decimal      @map("amount_paid") @db.Decimal(10, 2)
  currency         String       @default("INR")
  paymentRef       String?      @map("payment_ref")
  paymentMode      String?      @map("payment_mode")
  notes            String?
  createdById      String?      @map("created_by_id")
  lastModifiedById String?      @map("last_modified_by_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([expiryDate])
  @@map("tenant_licenses")
}

enum LicensePlan {
  STARTER
  STANDARD
  PROFESSIONAL
  ENTERPRISE
}

enum BillingCycle {
  DEMO
  ONE_TIME
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  TWO_YEARLY
  THREE_YEARLY
}
model Employee {
  id           String         @id @default(cuid())
  name         String
  phone        String
  role         String
  department   String
  baseSalary   Decimal        @map("base_salary") @db.Decimal(10, 2)
  salaryType   SalaryType     @map("salary_type")
  status       EmployeeStatus @default(ACTIVE)
  joinedAt     DateTime       @map("joined_at") @db.Date
  createdAt    DateTime       @default(now()) @map("created_at")
  attendance   Attendance[]
  payAdvances  PayAdvance[]
  payslipLines PayslipLine[]

  @@map("employees")
}

enum SalaryType {
  MONTHLY
  DAILY
  HOURLY
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

model Attendance {
  id              String           @id @default(cuid())
  employeeId      String           @map("employee_id")
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date            DateTime         @db.Date
  status          AttendanceStatus
  shiftStart      DateTime?        @map("shift_start") @db.Time
  shiftEnd        DateTime?        @map("shift_end") @db.Time
  overtimeMinutes Int              @default(0) @map("overtime_minutes")
  note            String?

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  ON_DUTY
}

model PayAdvance {
  id             String           @id @default(cuid())
  employeeId     String           @map("employee_id")
  employee       Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  amount         Decimal          @db.Decimal(10, 2)
  reason         String?
  status         PayAdvanceStatus @default(PENDING)
  requestedAt    DateTime         @default(now()) @map("requested_at")
  approvedAt     DateTime?        @map("approved_at")
  approvedBy     String?          @map("approved_by")
  recoveredIn    String?          @map("recovered_in")
  recoveredInRun PayrollRun?      @relation("RecoveredPayAdvances", fields: [recoveredIn], references: [id])

  @@index([employeeId])
  @@index([recoveredIn])
  @@map("pay_advances")
}

enum PayAdvanceStatus {
  PENDING
  APPROVED
  REJECTED
  RECOVERED
}

model PayrollRun {
  id                String        @id @default(cuid())
  period            String        @unique
  runAt             DateTime      @default(now()) @map("run_at")
  status            PayrollStatus @default(DRAFT)
  runBy             String?       @map("run_by")
  notes             String?
  payslipLines      PayslipLine[]
  recoveredAdvances PayAdvance[]  @relation("RecoveredPayAdvances")

  @@map("payroll_runs")
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

model PayslipLine {
  id               String     @id @default(cuid())
  payrollRunId     String     @map("payroll_run_id")
  payrollRun       PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId       String     @map("employee_id")
  employee         Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  daysWorked       Decimal    @map("days_worked") @db.Decimal(6, 2)
  overtimeHours    Decimal    @map("overtime_hours") @db.Decimal(8, 2)
  grossPay         Decimal    @map("gross_pay") @db.Decimal(10, 2)
  overtimePay      Decimal    @map("overtime_pay") @db.Decimal(10, 2)
  advancesDeducted Decimal    @map("advances_deducted") @db.Decimal(10, 2)
  otherDeductions  Decimal    @map("other_deductions") @db.Decimal(10, 2)
  netPay           Decimal    @map("net_pay") @db.Decimal(10, 2)
  breakdown        Json

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
  @@map("payslip_lines")
}
