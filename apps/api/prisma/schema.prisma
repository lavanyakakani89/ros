generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  vertical           VerticalType
  gstNumber          String?             @map("gst_number")
  gstEnabled         Boolean             @default(true) @map("gst_enabled")
  phone              String
  address            String?
  logoUrl            String?             @map("logo_url") @db.Text
  whatsappNotificationSettings Json       @default("{}") @map("whatsapp_notification_settings")
  loyaltyProgram     Json                @default("{}") @map("loyalty_program")
  requirePoApproval  Boolean             @default(false) @map("require_po_approval")
  timezone           String              @default("Asia/Kolkata")
  currency           String              @default("INR")
  status             TenantStatus        @default(ACTIVE)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  users              User[]
  stores             Store[]
  storeUserAssignments StoreUserAssignment[]
  products           Product[]
  productImageSuggestions ProductImageSuggestion[]
  productBatches     ProductBatch[]
  productVariants    ProductVariant[]
  stockAdjustments   StockAdjustment[]
  stockCounts        StockCount[]
  stockCountItems    StockCountItem[]
  customers          Customer[]
  invoices           Invoice[]
  invoiceCounters    InvoiceCounter[]
  invoiceItems       InvoiceItem[]
  deliveries         Delivery[]
  deliveryRoutes     DeliveryRoute[]
  deliveryRouteStops DeliveryRouteStop[]
  deliveryLocationPings DeliveryLocationPing[]
  payments           Payment[]
  paymentMethods     PaymentMethod[]
  partners           Partner[]
  settlements        Settlement[]
  payrollDisbursements PayrollDisbursement[]
  suppliers          Supplier[]
  purchaseOrders     PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  refreshTokens      RefreshToken[]
  categories         Category[]
  expenses           Expense[]
  creditNotes        CreditNote[]
  creditNoteItems    CreditNoteItem[]
  quotations         Quotation[]
  quotationItems     QuotationItem[]
  loyaltyAccounts    LoyaltyAccount[]
  loyaltyTransactions LoyaltyTransaction[]
  loyaltyTiers       LoyaltyTier[]
  coupons            Coupon[]
  auditLogs          AuditLog[]
  supplierPayments   SupplierPayment[]
  purchaseReturns    PurchaseReturn[]
  purchaseReturnItems PurchaseReturnItem[]
  restaurantTables   RestaurantTable[]
  menuCategories     MenuCategory[]
  menuModifierGroups MenuModifierGroup[]
  menuModifierOptions MenuModifierOption[]
  kots               KOT[]
  kotItems           KOTItem[]
  recipes            Recipe[]
  license            TenantLicense?
  storefrontSettings StorefrontSettings?
  storefrontDomains  StorefrontDomain[]
  storefrontApprovals StorefrontApprovalRequest[]
  moduleSubscriptions TenantModuleSubscription[]
  invoiceTemplates   InvoiceTemplate[]
  printerConfig      PrinterConfig?
  impersonationSessions ImpersonationSession[]
  appNotifications   AppNotification[]
  deliveryProofs     DeliveryProof[]
  whatsappIntegration WhatsappIntegration?
  whatsappMessageTemplates WhatsappMessageTemplate[]
  whatsappCampaigns WhatsappCampaign[]
  whatsappCampaignRecipients WhatsappCampaignRecipient[]
  employees          Employee[]
  employeeSalaryRevisions EmployeeSalaryRevision[]
  payrollRuns        PayrollRun[]

  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  WARNING
  SUSPENDED
}

enum VerticalType {
  PHARMACY
  GROCERY
  FASHION
  HARDWARE
  ELECTRONICS
  RESTAURANT
}

model User {
  id            String         @id @default(cuid())
  tenantId      String         @map("tenant_id")
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  primaryStoreId String?       @map("primary_store_id")
  primaryStore  Store?         @relation("UserPrimaryStore", fields: [primaryStoreId], references: [id], onDelete: SetNull)
  name          String
  email         String
  username      String?
  phone         String?
  passwordHash  String         @map("password_hash")
  role          UserRole       @default(STAFF)
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  refreshTokens RefreshToken[]
  appNotifications AppNotification[]
  pushTokens    ExpoPushToken[]
  approvedProductImageSuggestions ProductImageSuggestion[] @relation("ProductImageSuggestionApprovedBy")
  cashierPayments Payment[] @relation("PaymentCashier")
  voidedPayments Payment[] @relation("PaymentVoidAuthoriser")
  settledSettlements Settlement[] @relation("SettlementSettledBy")
  payrollDisbursements PayrollDisbursement[] @relation("PayrollDisbursementPaidBy")
  voidedPayrollDisbursements PayrollDisbursement[] @relation("PayrollDisbursementVoidAuthoriser")
  employeeSalaryRevisions EmployeeSalaryRevision[] @relation("EmployeeSalaryRevisionChangedBy")
  storeAssignments StoreUserAssignment[]


  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@index([tenantId])
  @@index([tenantId, primaryStoreId])
  @@map("users")
}

model ExpoPushToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String   @map("tenant_id")
  token     String   @unique
  platform  String   @default("android")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([tenantId])
  @@map("expo_push_tokens")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
  DELIVERY
}

model Store {
  id               String                @id @default(cuid())
  tenantId         String                @map("tenant_id")
  tenant           Tenant                @relation(fields: [tenantId], references: [id])
  name             String
  address          String?
  phone            String?
  isDefault        Boolean               @default(false) @map("is_default")
  isActive         Boolean               @default(true) @map("is_active")
  createdAt        DateTime              @default(now()) @map("created_at")
  primaryUsers     User[]                @relation("UserPrimaryStore")
  userAssignments  StoreUserAssignment[]
  invoices         Invoice[]
  paymentMethods   PaymentMethod[]
  partners         Partner[]
  purchaseOrders   PurchaseOrder[]
  expenses         Expense[]
  stockAdjustments StockAdjustment[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("stores")
}

model StoreUserAssignment {
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  storeId   String   @map("store_id")
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([storeId, userId])
  @@index([tenantId, userId])
  @@map("store_user_assignments")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tenantId, userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Category {
  id        String     @id @default(cuid())
  tenantId  String     @map("tenant_id")
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  name      String
  code      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  products  Product[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("categories")
}

model Product {
  id                 String              @id @default(cuid())
  tenantId           String              @map("tenant_id")
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  name               String
  sku                String?
  barcode            String?
  description        String?
  partGroup          String?             @map("part_group")
  legacySubCategoryId String?            @map("legacy_sub_category_id")
  unit               String              @default("piece")
  mrp                Decimal             @db.Decimal(10, 2)
  sellingPrice       Decimal             @map("selling_price") @db.Decimal(10, 2)
  purchasePrice      Decimal?            @map("purchase_price") @db.Decimal(10, 2)
  wholesalePrice     Decimal?            @map("wholesale_price") @db.Decimal(10, 2)
  defaultDiscountPercent Decimal?        @map("default_discount_percent") @db.Decimal(5, 2)
  gstRate            Decimal             @map("gst_rate") @db.Decimal(5, 2)
  cessRate           Decimal             @default(0) @map("cess_rate") @db.Decimal(5, 2)
  hsnCode            String?             @map("hsn_code")
  currentStock       Decimal             @default(0) @map("current_stock") @db.Decimal(10, 3)
  reorderLevel       Decimal?            @map("reorder_level") @db.Decimal(10, 3)
  purchaseUnit       String?             @map("purchase_unit")
  salesUnit          String?             @map("sales_unit")
  alternateUnit      String?             @map("alternate_unit")
  conversionValue    Decimal?            @map("conversion_value") @db.Decimal(10, 3)
  godown             String?
  rack               String?
  defaultSaleQty     Decimal?            @map("default_sale_qty") @db.Decimal(10, 3)
  supplierId         String?             @map("supplier_id")
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  categoryId         String?             @map("category_id")
  category           Category?           @relation(fields: [categoryId], references: [id])
  menuCategoryId     String?             @map("menu_category_id")
  menuCategory       MenuCategory?       @relation(fields: [menuCategoryId], references: [id])
  isActive           Boolean             @default(true) @map("is_active")
  ecommerceDisabled  Boolean             @default(false) @map("ecommerce_disabled")
  imageUrl           String?             @map("image_url") @db.Text
  verticalData       Json?               @map("vertical_data")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  invoiceItems       InvoiceItem[]
  batches            ProductBatch[]
  variants           ProductVariant[]
  stockAdjustments   StockAdjustment[]
  stockCountItems    StockCountItem[]
  purchaseOrderItems PurchaseOrderItem[]
  creditNoteItems    CreditNoteItem[]
  imageSuggestions    ProductImageSuggestion[]
  recipesAsMenu      Recipe[]            @relation("RecipeProduct")
  recipesAsIngredient Recipe[]           @relation("RecipeIngredient")

  @@unique([tenantId, sku])
  @@index([tenantId, barcode])
  @@index([tenantId, categoryId])
  @@index([tenantId, ecommerceDisabled])
  @@map("products")
}

model ProductImageSuggestion {
  id                String                         @id @default(cuid())
  tenantId          String                         @map("tenant_id")
  tenant            Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId         String                         @map("product_id")
  product           Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  provider          ProductImageSuggestionProvider @default(GOOGLE_CUSTOM_SEARCH)
  query             String                         @db.Text
  title             String                         @db.Text
  sourceImageUrl    String                         @map("source_image_url") @db.Text
  thumbnailUrl      String?                        @map("thumbnail_url") @db.Text
  contextUrl        String?                        @map("context_url") @db.Text
  mime              String?
  width             Int?
  height            Int?
  byteSize          Int?                           @map("byte_size")
  rights            String?
  relevance         ProductImageRelevance
  score             Int
  status            ProductImageSuggestionStatus   @default(SUGGESTED)
  storageObjectName String?                        @map("storage_object_name") @db.Text
  approvedById      String?                        @map("approved_by_id")
  approvedBy        User?                          @relation("ProductImageSuggestionApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt        DateTime?                      @map("approved_at")
  rejectedAt        DateTime?                      @map("rejected_at")
  createdAt         DateTime                       @default(now()) @map("created_at")
  updatedAt         DateTime                       @updatedAt @map("updated_at")

  @@index([tenantId, productId, status])
  @@index([tenantId, productId, score])
  @@index([approvedById])
  @@map("product_image_suggestions")
}

enum ProductImageSuggestionProvider {
  GOOGLE_CUSTOM_SEARCH
}

enum ProductImageRelevance {
  VERY_RELEVANT
  RELEVANT
  LOW
}

enum ProductImageSuggestionStatus {
  SUGGESTED
  APPROVED
  REJECTED
}

model ProductVariant {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  productId     String   @map("product_id")
  product       Product  @relation(fields: [productId], references: [id])
  name          String
  sku           String?
  barcode       String?
  sellingPrice  Decimal  @map("selling_price") @db.Decimal(10, 2)
  purchasePrice Decimal? @map("purchase_price") @db.Decimal(10, 2)
  mrp           Decimal  @db.Decimal(10, 2)
  currentStock  Decimal  @default(0) @map("current_stock") @db.Decimal(10, 3)
  attributes    Json?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId, productId])
  @@index([tenantId, barcode])
  @@map("product_variants")
}

model ProductBatch {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  productId     String    @map("product_id")
  product       Product   @relation(fields: [productId], references: [id])
  batchNumber   String    @map("batch_number")
  mfgDate       DateTime? @map("mfg_date")
  expiryDate    DateTime? @map("expiry_date")
  quantity      Decimal   @db.Decimal(10, 3)
  purchasePrice Decimal   @map("purchase_price") @db.Decimal(10, 2)
  receivedAt    DateTime  @default(now()) @map("received_at")

  @@index([tenantId, productId])
  @@index([expiryDate])
  @@map("product_batches")
}

model StockAdjustment {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  storeId        String?  @map("store_id")
  store          Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  productId      String   @map("product_id")
  product        Product  @relation(fields: [productId], references: [id])
  quantityChange Decimal  @map("quantity_change") @db.Decimal(10, 3)
  reason         String
  notes          String?
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([tenantId, productId])
  @@index([tenantId, storeId])
  @@map("stock_adjustments")
}

model StockCount {
  id          String           @id @default(cuid())
  tenantId    String           @map("tenant_id")
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  name        String
  status      String           @default("OPEN")
  countedAt   DateTime         @default(now()) @map("counted_at")
  submittedAt DateTime?        @map("submitted_at")
  approvedAt  DateTime?        @map("approved_at")
  createdBy   String           @map("created_by")
  approvedBy  String?          @map("approved_by")
  items       StockCountItem[]

  @@index([tenantId, status, countedAt])
  @@map("stock_counts")
}

model StockCountItem {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  stockCountId String     @map("stock_count_id")
  stockCount   StockCount @relation(fields: [stockCountId], references: [id])
  productId    String     @map("product_id")
  product      Product    @relation(fields: [productId], references: [id])
  productName  String     @map("product_name")
  systemQty    Decimal    @map("system_qty") @db.Decimal(10, 3)
  countedQty   Decimal?   @map("counted_qty") @db.Decimal(10, 3)
  variance     Decimal    @default(0) @db.Decimal(10, 3)

  @@unique([stockCountId, productId])
  @@index([tenantId, productId])
  @@map("stock_count_items")
}

model Customer {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  customerCode    String?          @map("customer_code")
  name            String
  phone           String
  email           String?
  address         String?
  city            String?
  state           String?
  postalCode      String?          @map("postal_code")
  remarks         String?
  accountNo       String?          @map("account_no")
  accountName     String?          @map("account_name")
  bank            String?
  branch          String?
  ifscCode        String?          @map("ifsc_code")
  gstin           String?
  pan             String?
  cin             String?
  birthday        DateTime?
  anniversary     DateTime?
  openingBalanceType String?       @map("opening_balance_type")
  openingBalance  Decimal          @default(0) @map("opening_balance") @db.Decimal(10, 2)
  tcsEnabled      Boolean          @default(false) @map("tcs_enabled")
  creditLimit     Decimal?         @map("credit_limit") @db.Decimal(10, 2)
  creditLimitEnabled Boolean       @default(false) @map("credit_limit_enabled")
  creditDays      Int?             @map("credit_days")
  tierId          String?          @map("tier_id")
  tier            LoyaltyTier?     @relation(fields: [tierId], references: [id], onDelete: SetNull)
  itemDiscountPercent Decimal      @default(0) @map("item_discount_percent") @db.Decimal(5, 2)
  itemDiscountEnabled Boolean      @default(false) @map("item_discount_enabled")
  outstandingDue  Decimal          @default(0) @map("outstanding_due") @db.Decimal(10, 2)
  ecommercePasswordHash String?     @map("ecommerce_password_hash")
  ecommerceLastLoginAt DateTime?    @map("ecommerce_last_login_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  invoices        Invoice[]
  deliveries      Delivery[]
  creditNotes     CreditNote[]
  quotations      Quotation[]
  loyaltyAccount  LoyaltyAccount?
  kots            KOT[]

  @@unique([tenantId, phone])
  @@unique([tenantId, customerCode])
  @@index([tenantId])
  @@index([tenantId, birthday])
  @@index([tenantId, anniversary])
  @@map("customers")
}

model Invoice {
  id                     String        @id @default(cuid())
  tenantId               String        @map("tenant_id")
  tenant                 Tenant        @relation(fields: [tenantId], references: [id])
  storeId                String?       @map("store_id")
  store                  Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  invoiceNumber          String        @map("invoice_number")
  customerId             String?       @map("customer_id")
  customer               Customer?     @relation(fields: [customerId], references: [id])
  invoiceDate            DateTime      @default(now()) @map("invoice_date")
  dueDate                DateTime?     @map("due_date")
  status                 InvoiceStatus @default(DRAFT)
  paymentMode            PaymentMode   @default(CASH) @map("payment_mode")
  paymentMethodId        String?       @map("payment_method_id")
  paymentMethod          PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  subtotal               Decimal       @db.Decimal(10, 2)
  totalDiscount          Decimal       @default(0) @map("total_discount") @db.Decimal(10, 2)
  totalCgst              Decimal       @default(0) @map("total_cgst") @db.Decimal(10, 2)
  totalSgst              Decimal       @default(0) @map("total_sgst") @db.Decimal(10, 2)
  totalIgst              Decimal       @default(0) @map("total_igst") @db.Decimal(10, 2)
  deliveryCharge         Decimal       @default(0) @map("delivery_charge") @db.Decimal(10, 2)
  grandTotal             Decimal       @map("grand_total") @db.Decimal(10, 2)
  amountPaid             Decimal       @default(0) @map("amount_paid") @db.Decimal(10, 2)
  amountDue              Decimal       @default(0) @map("amount_due") @db.Decimal(10, 2)
  loyaltyPointsEarned    Int           @default(0) @map("loyalty_points_earned")
  loyaltyPointsRedeemed  Int           @default(0) @map("loyalty_points_redeemed")
  couponCode             String?       @map("coupon_code")
  verticalData           Json?         @map("vertical_data")
  notes                  String?
  pdfUrl                 String?       @map("pdf_url")
  paymentLinkId          String?       @map("payment_link_id")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")
  items                  InvoiceItem[]
  payments               Payment[]
  delivery               Delivery?
  creditNotes            CreditNote[]
  kots                   KOT[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, invoiceDate])
  @@index([tenantId, storeId, invoiceDate])
  @@index([tenantId, customerId])
  @@index([tenantId, paymentLinkId])
  @@map("invoices")
}

model InvoiceCounter {
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  date      String
  nextSeq   Int      @default(1) @map("next_seq")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([tenantId, date])
  @@map("invoice_counters")
}

model InvoiceItem {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  invoiceId    String    @map("invoice_id")
  invoice      Invoice   @relation(fields: [invoiceId], references: [id])
  productId    String    @map("product_id")
  product      Product   @relation(fields: [productId], references: [id])
  productName  String    @map("product_name")
  quantity     Decimal   @db.Decimal(10, 3)
  unit         String
  mrp          Decimal   @db.Decimal(10, 2)
  sellingPrice Decimal   @map("selling_price") @db.Decimal(10, 2)
  discount     Decimal   @default(0) @db.Decimal(10, 2)
  gstRate      Decimal   @map("gst_rate") @db.Decimal(5, 2)
  cgst         Decimal   @db.Decimal(10, 2)
  sgst         Decimal   @db.Decimal(10, 2)
  total        Decimal   @db.Decimal(10, 2)
  batchNumber  String?   @map("batch_number")
  expiryDate   DateTime? @map("expiry_date")

  @@index([tenantId, invoiceId])
  @@map("invoice_items")
}

enum InvoiceStatus {
  DRAFT
  PENDING_WHATSAPP
  CONFIRMED
  PAID
  PARTIAL
  CANCELLED
}

enum PaymentMode {
  CASH
  UPI
  CARD
  CREDIT
  NETBANKING
}

enum PaymentMethodType {
  CASH
  UPI
  CARD
  CREDIT
  CUSTOM
}

enum SettlementFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum SettlementStatus {
  DRAFT
  REVIEWED
  SETTLED
}

model Partner {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  storeId         String          @map("store_id")
  store           Store           @relation(fields: [storeId], references: [id])
  name            String
  contactName     String?         @map("contact_name")
  contactPhone    String?         @map("contact_phone")
  contactEmail    String?         @map("contact_email")
  settlementTerms String?         @map("settlement_terms")
  createdAt       DateTime        @default(now()) @map("created_at")
  paymentMethods  PaymentMethod[]
  settlements     Settlement[]

  @@index([tenantId, storeId])
  @@map("partners")
}

model PaymentMethod {
  id                  String               @id @default(cuid())
  tenantId            String               @map("tenant_id")
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  storeId             String               @map("store_id")
  store               Store                @relation(fields: [storeId], references: [id])
  name                String               @db.VarChar(64)
  shortCode           String               @map("short_code") @db.VarChar(12)
  type                PaymentMethodType    @default(CUSTOM)
  color               String               @default("#1a6e4a") @db.VarChar(16)
  icon                String               @default("ti-cash") @db.VarChar(64)
