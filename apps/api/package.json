{
  "name": "@retailos/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "lint": "eslint .",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:verify-rls": "tsx prisma/verify-rls.ts",
    "prisma:seed": "tsx prisma/seed.ts",
    "superadmin:seed": "tsx prisma/seed-superadmin.ts",
    "start": "node dist/apps/api/src/server.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/plugins/rbac.spec.ts && tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@retailos/eslint-config": "workspace:*",
    "@types/qrcode": "^1.5.5",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@retailos/shared": "workspace:*",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@node-escpos/adapter-network": "npm:@node-escpos/network-adapter@0.0.1",
    "@node-escpos/core": "^0.6.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^5.22.0",
    "@retailos/vertical-configs": "workspace:^",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "bullmq": "^5.76.4",
    "dotenv": "^17.4.2",
    "expo-server-sdk": "^3.15.0",
    "fastify": "4",
    "fastify-plugin": "^5.1.0",
    "handlebars": "^4.7.9",
    "ioredis": "^5.10.1",
    "minio": "^8.0.7",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.42.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "tslib": "^2.8.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  }
}
