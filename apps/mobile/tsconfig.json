{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "types": ["react"],
    "paths": {
      "@/*": ["src/*"],
      "@bizbil/shared": ["../../packages/shared/src/index.ts"],
      "@bizbil/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts"],
  "exclude": ["app.config.ts", "scripts/**/*"]
}
