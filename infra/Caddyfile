{$APP_DOMAIN} {
  encode zstd gzip

  @pwaAssets path /sw.js /workbox-* /fallback-* /manifest.json
  header @pwaAssets Cache-Control "no-cache, no-store, must-revalidate"

  handle /api/* {
    reverse_proxy api:3001
  }

  handle /health {
    reverse_proxy api:3001
  }

  handle {
    reverse_proxy web:3000
  }
}

{$TEST_APP_DOMAIN:test.bizbil.com} {
  encode zstd gzip

  @pwaAssets path /sw.js /workbox-* /fallback-* /manifest.json
  header @pwaAssets Cache-Control "no-cache, no-store, must-revalidate"

  handle {
    reverse_proxy host.docker.internal:3100
  }
}

{$FILES_DOMAIN:files.ros.sivsanoils.in} {
  encode zstd gzip

  handle {
    reverse_proxy minio:9000
  }
}
