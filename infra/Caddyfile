{
  email {$ACME_EMAIL}
}

{$APP_DOMAIN} {
  encode zstd gzip

  @pwaAssets path /sw.js /workbox-* /fallback-* /manifest.json
  header @pwaAssets Cache-Control "no-cache, no-store, must-revalidate"

  handle /bizbil-landing* {
    respond "Not found" 404
  }

  handle /api/* {
    reverse_proxy api:3001
  }

  handle /health {
    reverse_proxy api:3001
  }

  handle {
    reverse_proxy web:3000
  }
}

www.bizbil.com {
  encode zstd gzip
  root * /srv/bizbil-site
  header Cache-Control "public, max-age=300"
  try_files {path} /index.html
  file_server
}

{$TEST_APP_DOMAIN:test-ros.sivsanoils.in} {
  encode zstd gzip

  @pwaAssets path /sw.js /workbox-* /fallback-* /manifest.json
  header @pwaAssets Cache-Control "no-cache, no-store, must-revalidate"

  handle {
    reverse_proxy host.docker.internal:3100
  }
}

{$FILES_DOMAIN:files.ros.sivsanoils.in} {
  encode zstd gzip

  handle {
    reverse_proxy minio:9000
  }
}
